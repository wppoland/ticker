/composer.lock
/package.json
/package-lock.json
/phpcs.xml.dist
/phpstan.neon.dist
/phpstan-baseline.neon
/README.md
/SPEC.md
/.DS_Store

.DS_Store
/.wordpress-org
/test-results
/playwright-report
/.playwright-mcp
