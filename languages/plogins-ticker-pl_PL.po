#. Plugin Name of the plugin
#: ticker.php
msgid "Ticker - Sales Countdown Timer for WooCommerce"
msgstr "Ticker - Zegar odliczający do końca promocji dla WooCommerce"

#. Plugin URI of the plugin
#: ticker.php
msgid "https://plogins.com/ticker/"
msgstr "https://plogins.com/ticker/"

#. Description of the plugin
#: ticker.php
msgid ""
"Show a live sale countdown timer on WooCommerce product pages to create "
"urgency and turn browsers into buyers."
msgstr ""
"Wyświetlaj na żywo zegar odliczający do końca promocji na stronach produktów "
"WooCommerce, aby budować poczucie pilności i zmieniać oglądających w "
"kupujących."

#. Author of the plugin
#: ticker.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: ticker.php
msgid "https://plogins.com/"
msgstr "https://plogins.com/"

